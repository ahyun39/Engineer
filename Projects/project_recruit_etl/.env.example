# .env 파일 템플릿 — 복사 후 실제 값으로 수정하세요.
# cp .env.example .env

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=saramin-jobs-raw
KAFKA_GROUP_ID=etl-worker

# ETL Worker 튜닝
FLUSH_SECONDS=30
POLL_INTERVAL_MS=5000
DATA_RETENTION_DAYS=7

# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX=saramin-jobs

# Scraper (크롤러 — 일회성 검증용)
SARAMIN_BASE_URL=https://www.saramin.co.kr
SCRAPE_PAGES=10
